---
import Layout from "../layouts/Layout.astro";
import About from "../components/review/About.astro";
import HowToPerticipate from "../components/review/HowToPerticipate.astro";
import Calender from "../components/common/Calender.astro";
import MeetYourTAs from "../components/cohortPages/common/MeetYourTAs.astro";
import MeetYourHosts from "../components/review/MeetYourHosts.astro";

const headerProps = {
  removeHeader: true,
};
const isVisible = true;
const img = "/review/hero.webp";
---

<Layout
  title="Pr Review Club"
  headerProps={headerProps}
  isVisible={isVisible}
>
  <div class="mx-auto mt-24 w-full max-w-[1360px] px-4 md:px-8 lg:mt-32">
    <div
      style={{
        backgroundImage: `url(${img})`,
        backgroundSize: "contain",
        backgroundRepeat: "no-repeat",
        backgroundPosition: "center",
      }}
      class="flex min-h-[30vh] w-full flex-col items-center justify-between rounded-2xl pb-12 pt-32 md:min-h-[60vh] lg:min-h-[90vh]"
    >
    </div>
  </div>
  <About />
  <HowToPerticipate />
  <Calender />
  <MeetYourHosts />
</Layout>
