---
import About from "../components/boss/about.astro";
import Things from "../components/boss/Things.astro";
import Speakers from "../components/boss/Speakers.astro";
import Footer from "../components/boss/Footer.astro";
import Gallery from "../components/boss/Gallery.astro";
import Schedule from "../components/boss/Schedule.astro";
import Navbar from "../components/boss/Navbar.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Join us Oct 26 - 31, 2026 in Jaipur for a week of Bitcoin Open Source development."
    />
    <meta name="viewport" content="width=device-width" />
    <link
      rel="icon"
      href="/footer/logo.png"
      sizes="any"
      type="image/svg+xml"
    />
    <meta name="generator" content={Astro.generator} />
    <title>BOSS Summit 2026 | Bitshala</title>

    <!-- Google tag (gtag.js) -->
    <script
      type="text/partytown"
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-MMXLBEEY37"
    ></script>
    <script type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());

      gtag("config", "G-MMXLBEEY37");
    </script>

    <!-- Facebook Meta Tags -->
    <meta
      property="og:url"
      content="https://bitshala.org/boss/"
    />
    <meta property="og:type" content="website" />
    <meta
      property="og:title"
      content="BOSS Summit 2026 | Bitcoin OSS Developer Summit | Bitshala"
    />
    <meta
      property="og:description"
      content="Join us Oct 26 - 31, 2026 in Jaipur for a week of Bitcoin Open Source development. Developers & designers sharing demos, workshops, and working on active GitHub repos."
    />
    <meta
      property="og:image"
      content="https://bitshala.org/boss/og-image.jpg"
    />

    <!-- Twitter Meta Tags -->
    <meta
      name="twitter:card"
      content="summary_large_image"
    />
    <meta
      property="twitter:domain"
      content="bitshala.org"
    />
    <meta
      property="twitter:url"
      content="https://bitshala.org/boss/"
    />
    <meta
      name="twitter:title"
      content="BOSS Summit 2026 | Bitcoin OSS Developer Summit | Bitshala"
    />
    <meta
      name="twitter:description"
      content="Join us Oct 26 - 31, 2026 in Jaipur for a week of Bitcoin Open Source development. Developers & designers sharing demos, workshops, and working on active GitHub repos."
    />
    <meta
      name="twitter:image"
      content="https://bitshala.org/boss/og-image.jpg"
    />
  </head>
  <body>
    <Navbar />
    <main class="bg-bossBg text-base text-white lg:text-lg">
      <section
        id="hero"
        class="flex w-full flex-col items-center justify-center gap-1 px-4 pb-4 pt-24 md:gap-2 md:px-8 md:pt-32 lg:min-h-screen lg:px-16 lg:pb-8 lg:pt-28"
      >
        <div
          class="flex flex-row flex-wrap items-center justify-center gap-5 font-boss md:gap-10"
        >
          <div class="flex items-center gap-3 md:gap-4">
            <img
              src="/boss/goa.webp"
              alt="Location"
              class="h-8 w-8 md:h-12 md:w-12"
            />
            <span class="text-2xl md:text-4xl">Jaipur</span>
          </div>
          <div class="flex items-center gap-3 md:gap-4">
            <img
              src="/boss/date.webp"
              alt="Date"
              class="h-8 w-8 md:h-12 md:w-12"
            />
            <span class="text-2xl md:text-4xl"
              >26 Oct - 31 Oct</span
            >
          </div>
        </div>

        <img
          src="/boss/hero.webp"
          alt="Bitshala BOSS Summit"
          class="h-auto w-full max-w-7xl object-contain lg:max-h-[70vh]"
        />

        <a
          href="https://luma.com/bitshalaboss"
          target="_blank"
          rel="noopener noreferrer"
          class="-mt-2 inline-block cursor-pointer rounded-lg bg-[#662c53] px-6 py-2 font-boss text-xl transition-colors hover:bg-[#9B6A8C] md:-mt-4 md:px-10 md:py-3 md:text-3xl lg:-mt-6"
        >
          Apply
        </a>
      </section>

      <section id="about">
        <About />
      </section>

      <section id="things">
        <Things />
      </section>

      <section id="agenda">
        <Schedule />
      </section>

      <section id="gallery">
        <Gallery />
      </section>

      <section id="Speakers">
        <Speakers />
      </section>

      <section id="footer">
        <Footer />
      </section>
    </main>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: "Dx Slight";
    src: url("/fonts/dx-slight/Dx-Slight-Medium-Tall.otf")
      format("opentype");
    font-weight: 500;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: "Londrina Shadow";
    src: url("/fonts/Londrina_Shadow/LondrinaShadow-Regular.ttf")
      format("truetype");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }
</style>
