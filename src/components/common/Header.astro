---
export interface Props {
  heading: string;
  subheading: string;
  image: string;
  headingColor: string;
  subheadingColor: string;
  isContain: boolean;
  overlayStyle?: Record<string, string>;
}

const {
  heading,
  subheading,
  image,
  headingColor,
  subheadingColor,
  overlayStyle,
} = Astro.props;
---

<main
  style={{
    backgroundImage: `url(${image})`,
    backgroundSize: "cover",
    backgroundRepeat: "no-repeat",
    backgroundPosition: "center",
  }}
  class="relative m-auto flex min-h-screen flex-col items-center justify-center bg-black px-5 pb-12 pt-32 md:rounded-lg"
>
  {overlayStyle && (
    <div class="absolute inset-0 md:rounded-lg" style={overlayStyle} />
  )}
  <div class="relative z-10 flex flex-col items-center justify-center">
    {
      heading && subheading ? (
        <>
          <h1
            class={`text-center font-header font-bold ${headingColor} text-3xl lg:text-8xl`}
          >
            {heading}
          </h1>
          <p
            class={`w-2/3 text-center text-xl ${subheadingColor} lg:text-4xl xl:mb-10`}
          >
            {subheading}
          </p>
          <div />
        </>
      ) : (
        <slot />
      )
    }
  </div>
</main>
