---
const summits = [
  {
    id: "summer-2026",
    label: "Summer 2026",
    images: [
      "/boss/summer2026/comic/1.webp",
      "/boss/summer2026/comic/2.webp",
      "/boss/summer2026/comic/3.webp",
      "/boss/summer2026/comic/4.webp",
      "/boss/summer2026/comic/5.webp",
      "/boss/summer2026/comic/6.webp",
      "/boss/summer2026/comic/7.webp",
      "/boss/summer2026/comic/8.webp",
      "/boss/summer2026/comic/9.webp",
    ],
  },
  {
    id: "summer-2025",
    label: "Summer 2025",
    images: [
      "/boss/gallery/image1.webp",
      "/boss/gallery/image2.webp",
      "/boss/gallery/image3.webp",
      "/boss/gallery/image4.webp",
      "/boss/gallery/image5.webp",
      "/boss/gallery/image6.webp",
      "/boss/gallery/image7.webp",
      "/boss/gallery/image8.webp",
    ],
    synopsisUrl: "/boss/winter-2025-synopsis",
  },
  {
    id: "winter-2025",
    label: "Winter 2025",
    images: [
      "/boss/winter_gallery/image1.webp",
      "/boss/winter_gallery/image2.webp",
      "/boss/winter_gallery/image3.webp",
      "/boss/winter_gallery/image4.webp",
      "/boss/winter_gallery/image5.webp",
      "/boss/winter_gallery/image6.webp",
      "/boss/winter_gallery/image7.webp",
    ],
    synopsisUrl: "/boss/summer-2025-synopsis",
  },
];

const desktopPositions = [
  "top-[3%] left-[7%] rotate-[-12deg] z-20",
  "top-[4%] left-[35%] rotate-[-8deg] z-30",
  "top-[5%] left-[63%] rotate-[-6deg] z-20",
  "top-[33%] left-[30%] rotate-[2deg] z-50",
  "top-[38%] left-[58%] rotate-[8deg] z-40",
  "top-[58%] left-[4%] rotate-[11deg] z-30",
  "top-[68%] left-[35%] rotate-[-7deg] z-20",
  "top-[61%] left-[66%] rotate-[-11deg] z-30",
  "top-[29%] left-[13%] rotate-[6deg] z-10",
];
---

<section
  id="gallery"
  class="w-full px-4 py-16 md:px-8 lg:px-24 xl:px-32"
>
  <!-- Header Container -->
  <div
    class="mb-12 flex flex-col items-start justify-between gap-6 md:flex-row md:items-end"
  >
    <!-- Heading -->
    <h2 class="font-boss text-4xl text-white md:text-6xl">
      Glimpse and
      <span class="bg-[#D7FF00] px-2 text-black"
        >highlight</span
      >
    </h2>

    <!-- Tabs -->
    <div class="flex flex-wrap gap-4">
      {
        summits.map((summit, index) => (
          <button
            data-tab={summit.id}
            class={`tab-button rounded-2xl border px-6 py-2 font-boss text-2xl lowercase transition-all duration-300 ${
              index === 0
                ? "border-[#D7FF00] text-[#D7FF00] shadow-[0_0_10px_rgba(215,255,0,0.3)]"
                : "border-[#6B4C5E] text-white/80 hover:border-[#D7FF00] hover:text-white"
            }`}
          >
            {summit.label.toLowerCase()}
          </button>
        ))
      }
    </div>
  </div>

  <!-- Galleries -->
  {
    summits.map((summit, index) => {
      return (
        <div
          data-gallery={summit.id}
          class={`gallery-content mt-10 ${index === 0 ? "" : "hidden"}`}
        >
          <div class="relative mx-auto hidden h-[720px] max-w-7xl md:block lg:h-[860px] xl:h-[920px]">
            {summit.images.map((image, i) => {
              return (
                <img
                  src={image}
                  alt={`${summit.label} gallery`}
                  loading="lazy"
                  class={`
                    absolute
                    aspect-[4/3]
                    w-[30%]
                    rounded-[2px]
                    border-[5px]
                    border-white
                    object-cover
                    shadow-[0_22px_55px_rgba(0,0,0,0.45)]
                    transition-all duration-300 ease-out
                    hover:z-50
                    hover:rotate-0
                    hover:scale-105
                    hover:shadow-[0_26px_70px_rgba(0,0,0,0.58)]
                    lg:border-[7px]
                    ${desktopPositions[i] || "left-0 top-0 z-10"}
                  `}
                />
              );
            })}
          </div>

          <div class="grid grid-cols-1 gap-4 md:hidden">
            {summit.images.map((image) => (
              <img
                src={image}
                alt={`${summit.label} gallery`}
                loading="lazy"
                class="h-24 w-full rounded-[2px] border-[5px] border-white object-cover shadow-[0_18px_40px_rgba(0,0,0,0.42)] transition-transform duration-300 md:h-44 lg:h-64"
              />
            ))}
          </div>
        </div>
      );
    })
  }
</section>

<script>
  const tabButtons =
    document.querySelectorAll(".tab-button");
  const galleryContents = document.querySelectorAll(
    ".gallery-content",
  );

  tabButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const targetTab = button.getAttribute("data-tab");

      tabButtons.forEach((btn) => {
        if (btn.getAttribute("data-tab") === targetTab) {
          btn.classList.add(
            "border-[#D7FF00]",
            "text-[#D7FF00]",
            "shadow-[0_0_10px_rgba(215,255,0,0.3)]",
          );
          btn.classList.remove(
            "border-[#6B4C5E]",
            "text-white/80",
          );
        } else {
          btn.classList.add(
            "border-[#6B4C5E]",
            "text-white/80",
          );
          btn.classList.remove(
            "border-[#D7FF00]",
            "text-[#D7FF00]",
            "shadow-[0_0_10px_rgba(215,255,0,0.3)]",
          );
        }
      });

      galleryContents.forEach((content) => {
        content.classList.toggle(
          "hidden",
          content.getAttribute("data-gallery") !==
            targetTab,
        );
      });
    });
  });
</script>
