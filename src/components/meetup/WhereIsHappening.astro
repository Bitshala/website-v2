---

<div class="mx-auto max-w-[1280px] px-4 lg:px-0">
  <div class="flex flex-col items-start gap-[60px] self-stretch">
    <h2
      class="font-header text-3xl font-bold text-[#333] lg:text-[48px] lg:leading-[77.612px]"
    >
      "Where is this happening?"
    </h2>

    <div class="flex flex-col gap-[48px]">
      <p
        class="font-base text-base font-medium text-[#333] text-justify lg:text-2xl lg:leading-[160%]"
      >
        Bitshala Local Meetups are currently active in multiple cities across
        India. Each city has its own rhythm, some run monthly, others are still
        finding their cadence. Join your city's group to stay in the loop.
      </p>

      <!-- City cards grid: 2 rows of 3 -->
      <div class="grid grid-cols-1 gap-7 md:grid-cols-2 lg:grid-cols-3">
        {
          cities.map((city) => (
            <div class="overflow-hidden rounded-[20px] border border-[#e0e0e0]">
              <div class="flex flex-col gap-7 bg-peach p-6">
                {/* Image with city name overlay */}
                <div class="relative h-[203px] w-full overflow-hidden rounded-lg shadow-md">
                  <img
                    src={city.image}
                    alt={city.name}
                    class="h-full w-full object-cover"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 rounded-lg backdrop-blur-[4px]" style="background: rgba(255,255,255,0.01);" />
                  <p
                    class="absolute bottom-2 left-5 font-header text-2xl font-bold text-white lg:text-4xl"
                    style="text-shadow: 1px 2px 3px rgba(0,0,0,0.28);"
                  >
                    {city.name}
                  </p>
                </div>

                {/* Card content */}
                <div class="flex flex-col gap-7 px-2 pb-3">
                  <div class="flex flex-col gap-5 text-black">
                    <p class="font-base text-xl font-bold leading-[1.3]">
                      City Lead:{" "}
                      <span class="underline">{city.lead}</span>
                    </p>
                    <div class="font-base text-xl leading-[1.3]" style="font-weight: 400;">
                      <p>{city.description}</p>
                      <p>{city.description2}</p>
                    </div>
                  </div>
                  <a
                    href={city.link}
                    class="font-header text-xl text-orange"
                    style="font-weight: 600;"
                  >
                    Join the group for updates →
                  </a>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- CTA Button -->
    <a
      href="https://lu.ma/bitshala"
      target="_blank"
      class="inline-flex h-[68px] items-center self-start rounded-xl bg-orange px-8 py-6 font-base text-lg font-bold text-white transition-opacity hover:opacity-90 lg:text-2xl"
    >
      See all our upcoming events on Luma →
    </a>
  </div>
</div>
