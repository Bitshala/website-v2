    image: "/meetups/b4ad75c53e6784fb5342386a0f183899a12ae0b6.png",
    lead: "Bala",
    description:
      "The starting point. Understand how Bitcoin actually works - transactions, mining, keys, scripting, and more.",
    description2: "Build your foundation right.",
    link: "#",
  },
  {
    name: "DELHI",
    image: "/meetups/791ecadd79e001f0b908c2ece47bee0bc597428b.png",
    lead: "Saurabh",
    description:
      "The starting point. Understand how Bitcoin actually works - transactions, mining, keys, scripting, and more.",
    description2: "Build your foundation right.",
    link: "#",
  },
  {
    name: "BIKANER",
    image: "/meetups/7ba690e8cc8f034cb76987a70c0010aa86089fac.png",
    lead: "Rajendra",
    description:
      "The starting point. Understand how Bitcoin actually works - transactions, mining, keys, scripting, and more.",
    description2: "Build your foundation right.",
    link: "#",
  },
  {
    name: "HYDERABAD",
    image: "/meetups/f07216c4c1cdc5291197a6b599d193a4afcc2dd7.png",
